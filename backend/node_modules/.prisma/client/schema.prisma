generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentOutboxStatus {
  PENDING
  SENT
  FAILED
}

enum CreditPurchaseStatus {
  PENDING
  COMPLETED
  FAILED
}

enum CreditTransactionType {
  REGISTRATION_BONUS
  REFEREE_REGISTRATION_BONUS
  REFERRER_FIRST_PURCHASE_BONUS
  CREDIT_PURCHASE
  CREDIT_CONSUMPTION
  ADMIN_ADJUSTMENT
}

enum ReferralRewardType {
  REFEREE_REGISTRATION
  REFERRER_FIRST_PURCHASE
}

model User {
  id                              String              @id @default(uuid()) @db.Uuid
  username                        String              @unique
  email                           String              @unique
  passwordHash                    String?
  firebaseUid                     String?             @unique
  role                            UserRole            @default(USER)
  creditsBalance                  Int                 @default(0)
  avatarUrl                       String?
  referralCode                    String              @unique
  referredByUserId                String?             @db.Uuid
  firstApprovedCreditPurchaseDone Boolean             @default(false)
  referralSignupBonusGranted      Boolean             @default(false)
  purchases                       Purchase[]
  creditTransactions              CreditTransaction[]
  creditPurchases                 CreditPurchase[]
  referredBy                      User?               @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referrals                       User[]              @relation("UserReferrals")
  referralRewardsAsReferrer       ReferralRewardLog[] @relation("ReferralRewardLogReferrer")
  referralRewardsAsReferee        ReferralRewardLog[] @relation("ReferralRewardLogReferee")
  createdAt                       DateTime            @default(now())
  updatedAt                       DateTime            @updatedAt

  @@index([referredByUserId])
  @@map("users")
}

model Movie {
  id         String     @id @default(uuid()) @db.Uuid
  title      String
  synopsis   String
  genre      String
  price      Decimal    @db.Decimal(10, 2)
  posterUrl  String?
  trailerUrl String?
  purchases  Purchase[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([createdAt(sort: Desc)])
  @@map("movies")
}

model Purchase {
  id                    String          @id @default(uuid()) @db.Uuid
  userId                String          @db.Uuid
  movieId               String          @db.Uuid
  amount                Decimal         @db.Decimal(10, 2)
  status                PurchaseStatus  @default(PENDING)
  provider              String
  correlationId         String          @unique @db.Uuid
  stripePaymentIntentId String?
  failureReason         String?
  outboxEvents          PaymentOutbox[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([movieId])
  @@index([status])
  @@map("purchases")
}

model PaymentAudit {
  id                    String         @id @default(uuid()) @db.Uuid
  purchaseId            String         @db.Uuid
  userId                String         @db.Uuid
  userName              String
  userEmail             String
  movieId               String         @db.Uuid
  movieTitle            String
  amount                Decimal        @db.Decimal(10, 2)
  provider              String
  status                PurchaseStatus
  correlationId         String         @db.Uuid
  stripePaymentIntentId String?
  eventType             String
  source                String
  message               String?
  createdAt             DateTime       @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([purchaseId])
  @@index([userId])
  @@index([movieId])
  @@index([status])
  @@map("payment_audits")
}

model PaymentOutbox {
  id            String              @id @default(uuid()) @db.Uuid
  purchaseId    String              @db.Uuid
  eventType     String
  payload       Json
  status        PaymentOutboxStatus @default(PENDING)
  attempts      Int                 @default(0)
  nextAttemptAt DateTime?
  lastError     String?
  publishedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([status, nextAttemptAt, createdAt])
  @@map("payment_outbox")
}

model CreditPlan {
  id            String           @id @default(uuid()) @db.Uuid
  name          String           @unique
  creditsAmount Int
  priceBrl      Decimal          @db.Decimal(10, 2)
  isActive      Boolean          @default(true)
  purchases     CreditPurchase[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([isActive, createdAt(sort: Desc)])
  @@map("credit_plans")
}

model CreditSystemConfig {
  id                                Int      @id
  registrationBonusCredits          Int      @default(250)
  referralEnabled                   Boolean  @default(true)
  refereeRegistrationBonusCredits   Int      @default(0)
  referrerFirstPurchaseBonusCredits Int      @default(0)
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt

  @@map("credit_system_config")
}

model CreditTransaction {
  id            String                @id @default(uuid()) @db.Uuid
  userId        String                @db.Uuid
  type          CreditTransactionType
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  description   String?
  correlationId String?
  metadata      Json?
  createdAt     DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, correlationId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([type])
  @@map("credit_transactions")
}

model CreditPurchase {
  id                    String                 @id @default(uuid()) @db.Uuid
  userId                String                 @db.Uuid
  creditPlanId          String                 @db.Uuid
  creditsAmount         Int
  amountBrl             Decimal                @db.Decimal(10, 2)
  status                CreditPurchaseStatus   @default(PENDING)
  provider              String
  correlationId         String                 @unique @db.Uuid
  stripePaymentIntentId String?
  failureReason         String?
  outboxEvents          CreditPurchaseOutbox[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditPlan CreditPlan @relation(fields: [creditPlanId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt(sort: Desc)])
  @@index([creditPlanId])
  @@index([status])
  @@map("credit_purchases")
}

model CreditPurchaseOutbox {
  id               String              @id @default(uuid()) @db.Uuid
  creditPurchaseId String              @db.Uuid
  eventType        String
  payload          Json
  status           PaymentOutboxStatus @default(PENDING)
  attempts         Int                 @default(0)
  nextAttemptAt    DateTime?
  lastError        String?
  publishedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  creditPurchase CreditPurchase @relation(fields: [creditPurchaseId], references: [id], onDelete: Cascade)

  @@index([creditPurchaseId])
  @@index([status, nextAttemptAt, createdAt])
  @@map("credit_purchase_outbox")
}

model ReferralRewardLog {
  id             String             @id @default(uuid()) @db.Uuid
  referrerUserId String             @db.Uuid
  refereeUserId  String             @db.Uuid
  rewardType     ReferralRewardType
  creditsGranted Int
  correlationId  String?
  createdAt      DateTime           @default(now())

  referrerUser User @relation("ReferralRewardLogReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  refereeUser  User @relation("ReferralRewardLogReferee", fields: [refereeUserId], references: [id], onDelete: Cascade)

  @@unique([refereeUserId, rewardType])
  @@unique([referrerUserId, refereeUserId, rewardType])
  @@index([referrerUserId, createdAt(sort: Desc)])
  @@index([refereeUserId, createdAt(sort: Desc)])
  @@map("referral_reward_logs")
}
